{
  "name": "acp-session-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config web/vite.config.js",
    "dev:api": "node server/index.js",
    "start": "concurrently -k -n api,web \"npm:dev:api\" \"npm:dev:web\"",
    "build:web": "vite build --config web/vite.config.js",
    "start:api": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.7",
    "@mui/material": "^6.1.7",
    "@reduxjs/toolkit": "^2.11.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react-redux": "^9.2.0",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.2"
  }
}
