{
  "name": "acp-session-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config web/vite.config.ts",
    "dev:api": "tsx server/index.ts",
    "start": "concurrently -k -n api,web \"npm:dev:api\" \"npm:dev:web\"",
    "build:web": "vite build --config web/vite.config.ts",
    "start:api": "NODE_ENV=production tsx server/index.ts",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.7",
    "@mui/material": "^6.1.7",
    "@reduxjs/toolkit": "^2.11.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react-redux": "^9.2.0",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.0.1",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
