# ── FoxOps Dashboard — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# .env lives at the repo root alongside package.json.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express API listens on (default: 8787)
PORT=8787

# A long random secret for signing session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── Admin user (local auth) ────────────────────────────────────────────────────
# Used ONCE to seed the first user into the SQLite DB (~/.foxops/foxops.db).
# After the first server start these are ignored — change your password in the
# admin panel once it exists.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5177/auth/google/callback (dev)
#                          https://your-domain.com/auth/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google account emails allowed to sign in via OAuth.
# Leave blank to allow any Google account (not recommended for production).
ALLOWED_EMAILS=you@example.com

# ── URLs ──────────────────────────────────────────────────────────────────────

# Base URL of THIS app — used for OAuth callback and post-login redirects.
# Dev: http://localhost:5177  |  Prod: https://your-domain.com
APP_BASE_URL=http://localhost:5177

# ── FoxMemory ─────────────────────────────────────────────────────────────────

# Base URL of foxmemory-store and the user ID to use for API requests.
FOXMEMORY_BASE_URL=
FOXMEMORY_USER_ID=

# Optional: override Qdrant URL (defaults to FOXMEMORY_BASE_URL host on :6333)
# QDRANT_BASE_URL=

# ── OpenClaw Gateway ──────────────────────────────────────────────────────────

# WebSocket URL of the OpenClaw Gateway.
# Local default works when running on the same machine as openclaw.
# For containerized deployments, point at the gateway over Tailscale:
#   OPENCLAW_GATEWAY_URL=wss://<tailscale-hostname>:18789
OPENCLAW_GATEWAY_URL=ws://localhost:18789

# Shared token required by the gateway (from openclaw config get gateway.auth.token).
# In local dev this is auto-read from ~/.openclaw/openclaw.json when left blank.
# Must be set explicitly in containerized / remote deployments.
OPENCLAW_GATEWAY_TOKEN=

# ── Misc ──────────────────────────────────────────────────────────────────────

# Directory where foxops.db (SQLite auth DB) is stored.
# In Docker this is /data (mounted as a named volume). Locally defaults to ~/.foxops
# FOXOPS_DB_DIR=/data
